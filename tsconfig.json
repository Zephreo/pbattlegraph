{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "None",
    "outDir": "./",
    "rootDir": "./",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noEmitOnError": false,
    "declaration": false,
    "sourceMap": false,
    "allowJs": false,
    "skipLibCheck": true
  },
  "include": ["./*.ts"],
  "exclude": ["node_modules"]
}
